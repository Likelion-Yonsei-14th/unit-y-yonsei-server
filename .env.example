SPRING_PROFILES_ACTIVE=dev
PORT=8080

DB_URL=jdbc:mysql://RDS_ENDPOINT:3306/DB_NAME?useSSL=false&characterEncoding=UTF-8&serverTimezone=Asia/Seoul&allowPublicKeyRetrieval=true
DB_USERNAME=DB_USERNAME
DB_PASSWORD=DB_PASSWORD

SPRING_SESSION_STORE_TYPE=redis
REDIS_HOST=redis
REDIS_PORT=6379

SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=none
SERVER_FORWARD_HEADERS_STRATEGY=framework

JPA_SHOW_SQL=false

AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

APP_CORS_ALLOWED_ORIGINS=https://your-admin-domain.com,http://localhost:3000